# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Fallback API Key for OpenRouter
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# APP_DOMAIN
APP_DOMAIN="http://localhost:3000"

# APP_NAME
APP_NAME="YourAppName"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="YOUR_APP_URL"

# SUPABASE_URL: The API URL endpoint of your Supabase project.
SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"

# SUPABASE_KEY: The public anon or service_role key of your Supabase database.
SUPABASE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# GEMINI_MODEL: The default Gemini AI model for processing evaluations.
GEMINI_MODEL="gemini-3.5-flash"

# GOOGLE_CLIENT_ID: Your Google Cloud Console OAuth Client ID
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: Your Google Cloud Console OAuth Client Secret
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# TAVILY_API_KEY: Fallback search provider
TAVILY_API_KEY="YOUR_TAVILY_API_KEY"

# SERPER_API_KEY: Fallback search provider
SERPER_API_KEY="YOUR_SERPER_API_KEY"

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins for the Python backend in production environments.
# Example: https://schemeconnect-ap.example.com,https://schemeconnect-tg.example.com
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"